{
  "name": "longhouse-client",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Longhouse SPA client — SolidJS + Vite + CBOR",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:watch": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.3",
    "cbor-x": "^1.6.0",
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-solid": "^2.11.1",
    "vitest": "^4.1.6"
  }
}
