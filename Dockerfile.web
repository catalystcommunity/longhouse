# Build + serve the Longhouse SPA. Two-stage: a Node build produces the
# Vite output, then Caddy serves it. The image carries no app secrets —
# `/api/*` is expected to be routed to the api Service by the Gateway
# upstream of this container, so the SPA's relative `/api/...` fetches
# reach the api in production.

FROM node:22-alpine AS builder
WORKDIR /build
COPY client/package.json client/package-lock.json* ./client/
RUN cd client && npm ci
COPY client/ ./client/
RUN cd client && npm run build

FROM caddy:2-alpine
COPY --from=builder /build/client/dist /usr/share/caddy
COPY client/Caddyfile /etc/caddy/Caddyfile

# The upstream caddy image runs `setcap cap_net_bind_service=+ep` on
# /usr/bin/caddy so it can bind 80/443 without root. That file
# capability is incompatible with PSA-restricted's
# allowPrivilegeEscalation: false — the kernel refuses to exec the
# binary (EPERM: "operation not permitted"). We bind :4080, which is
# non-privileged, so the capability is unnecessary. Strip it.
RUN setcap -r /usr/bin/caddy || true

# Caddy creates its XDG storage dirs at startup even when no feature
# uses them. With readOnlyRootFilesystem: true on the pod, /data and
# /config are unwritable at runtime — redirect to /tmp (the only path
# k8s reliably gives us as a writable tmpfs).
ENV XDG_CONFIG_HOME=/tmp/caddy-config
ENV XDG_DATA_HOME=/tmp/caddy-data

EXPOSE 4080
USER 1000:1000
