# Local-dev env for the longhouse api. Sourced by `./tools run-api` and
# `./tools dev`. Gitignored — values here are non-secret because they
# only authenticate against the local Postgres in docker-compose.

# DB lives in the longhouse-postgres-dev container on host port 5433.
# (5432 is reserved for whatever else you might have running locally.)
LONGHOUSE_DB_URI=postgresql://longhouse:devpass123@localhost:5433/longhouse_db?sslmode=disable

# Ports the api listens on (kept identical to prod for fewer surprises).
LONGHOUSE_API_PORT=6080
LONGHOUSE_TCP_PORT=6081

# Dev-only knobs — the api refuses to register the /api/v1/dev/* endpoints
# unless ENV is dev/nonprod AND the flag is true. JWT_SECRET just needs to
# be set; minted tokens live in this machine's browser only.
LONGHOUSE_ENV=dev
LONGHOUSE_DEV_AUTH_ENABLED=true
LONGHOUSE_JWT_SECRET=dev-only-jwt-secret-not-for-prod

# Bootstrap one admin member on first boot so /dev-login isn't empty. The
# UUID matches Tod's linkkeys identity in prod (deploy/values-todandlorna.yaml)
# so signing in locally feels native. The house is intentionally named
# differently from prod so a glance at the header tells you which DB you're
# pointed at. SeedInitialAdmin no-ops once any member exists, so this is
# safe to leave set forever.
LONGHOUSE_INITIAL_ADMIN_DOMAIN=localdev.localhost
LONGHOUSE_INITIAL_ADMIN_USER_ID=0000beef-14db-7303-8a5a-e63fbe233c39
LONGHOUSE_INITIAL_HOUSE_NAME="Local Dev House"

# Browser-flow auth is intentionally NOT configured here. /dev-login is the
# local sign-in path; the real linkkeys assertion flow only makes sense
# against a deployed RP. If you want to exercise it locally, set:
#   LONGHOUSE_LINKKEYS_PKI_URL, LONGHOUSE_LINKKEYS_PKI_API_KEY,
#   LONGHOUSE_LINKKEYS_IDP_DOMAIN, LONGHOUSE_LINKKEYS_IDP_URL,
#   LONGHOUSE_APP_CALLBACK_URL=http://localhost:5173/auth/callback
